{% extends "basefront.html.twig" %}

{% block body %}
    <div class="row mt-3">
        <div class="col-md-8 offset-md-2">
            <h3 class="text-info mb-4">Back-Office : Gestion des Catégories</h3>
            
            {% for message in app.flashes('danger') %}
                <div class="alert alert-danger">
                    {{ message }}
                </div>
            {% endfor %}

            <div class="card p-3 mb-4 bg-light">
                <h5 class="text-secondary">Ajouter une nouvelle catégorie</h5>
                {{ form_start(formcategorie, {'attr': {'class': 'd-flex align-items-end gap-3'}}) }}
                    <div class="flex-grow-1">
                        {{ form_row(formcategorie.name) }}
                    </div>
                    <div class="mb-3">
                        {{ form_row(formcategorie.submit) }}
                    </div>
                {{ form_end(formcategorie) }}
            </div>

            <table class="table table-striped">
                <thead>
                    <tr>
                        <th class="text-left align-top" scope="col">Nom de la catégorie</th>
                        <th class="text-center align-top" scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% if categories|length > 0 %}
                        {% for categorie in categories %}
                            <tr class="align-middle">
                                <td class="text-left">
                                    {{ categorie.name }}
                                </td>
                                <td class="text-center">
                                    <a href="{{ path('admin_categories.suppr', {id:categorie.id}) }}" class="btn btn-danger btn-sm" onclick="return confirm('Êtes-vous sûr de vouloir supprimer la catégorie : {{ categorie.name|escape('js') }} ?')">Supprimer</a>
                                </td>
                            </tr>
                        {% endfor %}
                    {% else %}
                        <tr>
                            <td colspan="2" class="text-center">Aucune catégorie existante.</td>
                        </tr>
                    {% endif %}
                </tbody>
            </table>

        </div>
    </div>
{% endblock %}