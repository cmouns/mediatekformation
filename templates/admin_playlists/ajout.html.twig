{% extends "basefront.html.twig" %}

{% block body %}
    <div class="row mt-5">
        <div class="col-md-8 offset-md-2">
            <h3 class="text-info mb-4">Ajouter une nouvelle playlist</h3>
            
            <div class="card p-4 bg-light">
                {{ form_start(formplaylist) }}
                {{ form_widget(formplaylist) }}
                
                <div class="mt-3">
                    <a href="{{ path('admin_playlists') }}" class="btn btn-secondary">Annuler et retourner à la liste</a>
                </div>
                {{ form_end(formplaylist) }}
            </div>
        </div>
    </div>
{% endblock %}