{% extends "basefront.html.twig" %}

{% block body %}
    <div class="row mt-5">
        <div class="col-md-8 offset-md-2">
            <h3 class="text-info mb-4">Modifier la playlist : {{ playlist.name }}</h3>
            
            <div class="card p-4 bg-light">
                {{ form_start(formplaylist) }}
                {{ form_widget(formplaylist) }}
                
                <div class="mt-3">
                    <a href="{{ path('admin_playlists') }}" class="btn btn-secondary">Annuler et retourner à la liste</a>
                </div>
                {{ form_end(formplaylist) }}
            </div>

            <div class="mt-5">
                <h4 class="text-info">Formations rattachées à cette playlist</h4>
                <p class="text-muted small">L'ajout ou la suppression de formations se fait uniquement depuis la gestion des formations.</p>
                
                {% if formations|length > 0 %}
                    <ul class="list-group">
                        {% for formation in formations %}
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                {{ formation.title }}
                                <span class="badge bg-info rounded-pill">{{ formation.publishedAt|date('d/m/Y') }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <div class="alert alert-info">Aucune formation n'est actuellement rattachée à cette playlist.</div>
                {% endif %}
            </div>

        </div>
    </div>
{% endblock %}